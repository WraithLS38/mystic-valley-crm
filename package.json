<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mystic Valley Farm - AI CRM</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://sites.super.myninja.ai/_assets/ninja-daytona-script.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <i class="fas fa-leaf"></i>
                <span>Mystic Valley Farm</span>
            </div>
            <nav class="nav-menu">
                <a href="#" class="nav-item active" data-view="dashboard">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                <a href="#" class="nav-item" data-view="leads">
                    <i class="fas fa-users"></i>
                    <span>Leads</span>
                </a>
                <a href="#" class="nav-item" data-view="scraper">
                    <i class="fas fa-robot"></i>
                    <span>AI Lead Scraper</span>
                </a>
                <a href="#" class="nav-item" data-view="emails">
                    <i class="fas fa-envelope"></i>
                    <span>Email Campaigns</span>
                </a>
                <a href="#" class="nav-item" data-view="orders">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Orders</span>
                </a>
                <a href="#" class="nav-item" data-view="products">
                    <i class="fas fa-box"></i>
                    <span>Products</span>
                </a>
                <a href="#" class="nav-item" data-view="settings">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="header">
                <h1 id="page-title">Dashboard</h1>
                <div class="header-actions">
                    <button class="btn btn-primary" id="quick-add-lead">
                        <i class="fas fa-plus"></i> Add Lead
                    </button>
                </div>
            </header>

            <!-- Dashboard View -->
            <div id="dashboard-view" class="view active">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon leads"><i class="fas fa-users"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-total-leads">0</h3>
                            <p>Total Leads</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon hot"><i class="fas fa-fire"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-hot-leads">0</h3>
                            <p>Hot Leads</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon contacted"><i class="fas fa-envelope-open"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-contacted">0</h3>
                            <p>Contacted</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon customers"><i class="fas fa-handshake"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-customers">0</h3>
                            <p>Customers</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orders"><i class="fas fa-shopping-cart"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-orders">0</h3>
                            <p>Total Orders</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon revenue"><i class="fas fa-dollar-sign"></i></div>
                        <div class="stat-info">
                            <h3 id="stat-revenue">$0</h3>
                            <p>Revenue</p>
                        </div>
                    </div>
                </div>

                <div class="dashboard-sections">
                    <div class="section">
                        <h2><i class="fas fa-fire"></i> Hot Leads</h2>
                        <div id="hot-leads-list" class="leads-preview"></div>
                    </div>
                    <div class="section">
                        <h2><i class="fas fa-clock"></i> Recent Activity</h2>
                        <div id="recent-activity" class="activity-list"></div>
                    </div>
                </div>
            </div>

            <!-- Leads View -->
            <div id="leads-view" class="view">
                <div class="toolbar">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" id="lead-search" placeholder="Search leads...">
                    </div>
                    <div class="filters">
                        <select id="status-filter">
                            <option value="">All Status</option>
                            <option value="new">New</option>
                            <option value="qualified">Qualified</option>
                            <option value="contacted">Contacted</option>
                            <option value="customer">Customer</option>
                        </select>
                        <select id="rank-filter">
                            <option value="">All Ranks</option>
                            <option value="hot">Hot</option>
                            <option value="warm">Warm</option>
                            <option value="cold">Cold</option>
                            <option value="unqualified">Unqualified</option>
                        </select>
                        <button class="btn btn-secondary" id="enrich-all-btn">
                            <i class="fas fa-search-plus"></i> Enrich All
                        </button>
                        <button class="btn btn-secondary" id="qualify-all-btn">
                            <i class="fas fa-check-double"></i> Qualify All
                        </button>
                    </div>
                </div>
                <div class="table-container">
                    <table class="data-table" id="leads-table">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="select-all-leads"></th>
                                <th>Company</th>
                                <th>Contact</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Score</th>
                                <th>Rank</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="leads-tbody"></tbody>
                    </table>
                </div>
                <div class="bulk-actions" id="bulk-actions" style="display: none;">
                    <span id="selected-count">0 selected</span>
                    <button class="btn btn-primary" id="bulk-email-btn">
                        <i class="fas fa-envelope"></i> Send Email
                    </button>
                    <button class="btn btn-danger" id="bulk-delete-btn">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>

            <!-- AI Scraper View -->
            <div id="scraper-view" class="view">
                <div class="scraper-container">
                    <div class="scraper-form card">
                        <h2><i class="fas fa-robot"></i> AI Lead Scraper</h2>
                        <p>Use our AI agent to find potential wholesale customers across the internet.</p>
                        
                        <div class="form-group">
                            <label>Business Type</label>
                            <select id="scraper-business-type">
                                <option value="cafe">Cafes & Coffee Shops</option>
                                <option value="restaurant">Restaurants</option>
                                <option value="tea">Tea Shops</option>
                                <option value="spa">Spas & Wellness Centers</option>
                                <option value="hotel">Hotels</option>
                                <option value="grocery">Grocery Stores</option>
                                <option value="retail">Retail Shops</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Location</label>
                            <input type="text" id="scraper-location" placeholder="e.g., San Francisco, CA">
                        </div>
                        <div class="form-group">
                            <label>Additional Keywords (optional)</label>
                            <input type="text" id="scraper-keywords" placeholder="e.g., organic, specialty, premium">
                        </div>
                        <button class="btn btn-primary btn-lg" id="start-scraper">
                            <i class="fas fa-search"></i> Find Leads
                        </button>
                    </div>

                    <div class="scraper-results card" id="scraper-results" style="display: none;">
                        <div class="results-header">
                            <h3><i class="fas fa-list"></i> Found <span id="found-count">0</span> Leads</h3>
                            <div class="results-actions">
                                <button class="btn btn-secondary" id="select-all-results">Select All</button>
                                <button class="btn btn-primary" id="import-selected">Import Selected</button>
                            </div>
                        </div>
                        <div class="results-list" id="results-list"></div>
                    </div>
                </div>
            </div>

            <!-- Emails View -->
            <div id="emails-view" class="view">
                <div class="email-container">
                    <div class="email-templates card">
                        <h2><i class="fas fa-file-alt"></i> Email Templates</h2>
                        <div class="template-list">
                            <div class="template-item active" data-template="initial">
                                <i class="fas fa-handshake"></i>
                                <span>Initial Outreach</span>
                            </div>
                            <div class="template-item" data-template="followup">
                                <i class="fas fa-redo"></i>
                                <span>Follow Up</span>
                            </div>
                            <div class="template-item" data-template="custom">
                                <i class="fas fa-edit"></i>
                                <span>Custom Email</span>
                            </div>
                        </div>
                    </div>
                    <div class="email-composer card">
                        <h2><i class="fas fa-pen"></i> Compose Email</h2>
                        <div class="form-group">
                            <label>To (Recipients)</label>
                            <div id="email-recipients" class="recipients-list"></div>
                        </div>
                        <div class="form-group">
                            <label>Subject</label>
                            <input type="text" id="email-subject" placeholder="Email subject...">
                        </div>
                        <div class="form-group">
                            <label>Message</label>
                            <textarea id="email-body" rows="15" placeholder="Email content..."></textarea>
                        </div>
                        <div class="composer-actions">
                            <button class="btn btn-secondary" id="preview-email">
                                <i class="fas fa-eye"></i> Preview
                            </button>
                            <button class="btn btn-primary" id="send-email">
                                <i class="fas fa-paper-plane"></i> Send Email
                            </button>
                        </div>
                    </div>
                </div>

                <div class="email-history card">
                    <h2><i class="fas fa-history"></i> Recent Emails</h2>
                    <div id="email-history-list" class="history-list"></div>
                </div>
            </div>

            <!-- Orders View -->
            <div id="orders-view" class="view">
                <div class="toolbar">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" id="order-search" placeholder="Search orders...">
                    </div>
                    <div class="filters">
                        <select id="order-status-filter">
                            <option value="">All Status</option>
                            <option value="pending">Pending</option>
                            <option value="processing">Processing</option>
                            <option value="shipped">Shipped</option>
                            <option value="completed">Completed</option>
                            <option value="cancelled">Cancelled</option>
                        </select>
                        <button class="btn btn-primary" id="new-order-btn">
                            <i class="fas fa-plus"></i> New Order
                        </button>
                    </div>
                </div>
                <div class="table-container">
                    <table class="data-table" id="orders-table">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="orders-tbody"></tbody>
                    </table>
                </div>
            </div>

            <!-- Products View -->
            <div id="products-view" class="view">
                <div class="products-header">
                    <h2>Wholesale Pricing & Products</h2>
                    <div class="discount-info">
                        <h3>Volume Discounts</h3>
                        <div class="discount-tiers">
                            <div class="tier"><strong>1 Case:</strong> 25% off</div>
                            <div class="tier"><strong>2 Cases:</strong> 30% off</div>
                            <div class="tier"><strong>3 Cases:</strong> 35% off</div>
                            <div class="tier"><strong>4+ Cases:</strong> 40% off</div>
                        </div>
                    </div>
                </div>
                <div id="products-list" class="products-grid"></div>
            </div>

            <!-- Settings View -->
            <div id="settings-view" class="view">
                <div class="settings-container">
                    <div class="settings-section card">
                        <h2><i class="fas fa-robot"></i> AI Settings</h2>
                        <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem;">Enter your OpenAI API key to enable AI-powered email generation and response drafting.</p>
                        <div class="form-group">
                            <label>OpenAI API Key</label>
                            <input type="password" id="openai-key" placeholder="sk-...">
                        </div>
                        <button class="btn btn-primary" id="save-openai">
                            <i class="fas fa-save"></i> Save AI Settings
                        </button>
                    </div>

                    <div class="settings-section card">
                        <h2><i class="fas fa-search"></i> Lead Scraping Settings</h2>
                        <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem;">Enter your SerpAPI key to enable real lead scraping from Google search results. Without this, the system will use demo lead data.</p>
                        <div class="form-group">
                            <label>SerpAPI Key</label>
                            <input type="password" id="serpapi-key" placeholder="Your SerpAPI key...">
                        </div>
                        <button class="btn btn-primary" id="save-serpapi">
                            <i class="fas fa-save"></i> Save Scraping Settings
                        </button>
                    </div>

                    <div class="settings-section card">
                        <h2><i class="fas fa-envelope"></i> Email Settings (SMTP)</h2>
                        <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem;">Configure your email to send automated outreach and order notifications.</p>
                        <div class="form-group">
                            <label>SMTP Host</label>
                            <input type="text" id="smtp-host" placeholder="smtp.gmail.com">
                        </div>
                        <div class="form-group">
                            <label>Port</label>
                            <input type="number" id="smtp-port" placeholder="587">
                        </div>
                        <div class="form-group">
                            <label>Username (Email)</label>
                            <input type="email" id="smtp-user" placeholder="your-email@gmail.com">
                        </div>
                        <div class="form-group">
                            <label>Password (App Password)</label>
                            <input type="password" id="smtp-pass" placeholder="Your app password">
                        </div>
                        <button class="btn btn-primary" id="save-smtp">
                            <i class="fas fa-save"></i> Save SMTP Settings
                        </button>
                    </div>

                    <div class="settings-section card">
                        <h2><i class="fas fa-building"></i> Business Information</h2>
                        <div class="form-group">
                            <label>Company Name</label>
                            <input type="text" id="company-name" placeholder="Mystic Valley Farm">
                        </div>
                        <div class="form-group">
                            <label>Business Email (for replies)</label>
                            <input type="email" id="business-email" placeholder="steven@themysticvalleyfarm.com">
                        </div>
                        <button class="btn btn-primary" id="save-business">
                            <i class="fas fa-save"></i> Save Business Settings
                        </button>
                    </div>

                    <div class="settings-section card">
                        <h2><i class="fas fa-truck"></i> Delivery Information</h2>
                        <div class="info-box" style="background: var(--bg-input); padding: 1rem; border-radius: var(--radius-sm);">
                            <p><strong>Free Delivery Zone:</strong> Within 60 miles of Rogue River, OR 97537</p>
                            <p style="margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.9rem;">Orders from customers within this radius automatically get free shipping calculated in the order form.</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modals -->
    <div class="modal-overlay" id="modal-overlay"></div>
    
    <!-- Add/Edit Lead Modal -->
    <div class="modal" id="lead-modal">
        <div class="modal-header">
            <h2 id="lead-modal-title">Add Lead</h2>
            <button class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <form id="lead-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Company Name *</label>
                        <input type="text" name="company" required>
                    </div>
                    <div class="form-group">
                        <label>Contact Name</label>
                        <input type="text" name="name">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="tel" name="phone">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Website</label>
                        <input type="url" name="website" placeholder="https://...">
                    </div>
                    <div class="form-group">
                        <label>Industry</label>
                        <select name="industry">
                            <option value="">Select...</option>
                            <option value="cafe">Cafe / Coffee Shop</option>
                            <option value="restaurant">Restaurant</option>
                            <option value="tea">Tea Shop</option>
                            <option value="spa">Spa / Wellness</option>
                            <option value="hotel">Hotel</option>
                            <option value="grocery">Grocery</option>
                            <option value="retail">Retail</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="location" placeholder="City, State">
                    </div>
                    <div class="form-group">
                        <label>Source</label>
                        <select name="source">
                            <option value="organic">Organic</option>
                            <option value="referral">Referral</option>
                            <option value="scraper">AI Scraper</option>
                            <option value="website">Website</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Estimated Volume</label>
                    <select name="estimatedVolume">
                        <option value="">Unknown</option>
                        <option value="small">1-2 cases/month</option>
                        <option value="medium">3-5 cases/month</option>
                        <option value="large">6+ cases/month</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="3"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary modal-cancel">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Lead</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Order Modal -->
    <div class="modal" id="order-modal">
        <div class="modal-header">
            <h2 id="order-modal-title">New Order</h2>
            <button class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <form id="order-form">
                <div class="form-group">
                    <label>Customer</label>
                    <select name="leadId" id="order-customer">
                        <option value="">Select customer...</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Products</label>
                    <div id="order-products" class="order-products-list"></div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Subtotal</label>
                        <input type="text" id="order-subtotal" readonly>
                    </div>
                    <div class="form-group">
                        <label>Discount</label>
                        <select id="order-discount">
                            <option value="0.25">25% (1 Case)</option>
                            <option value="0.30">30% (2 Cases)</option>
                            <option value="0.35">35% (3 Cases)</option>
                            <option value="0.40">40% (4+ Cases)</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Shipping</label>
                        <input type="number" id="order-shipping" value="0" step="0.01">
                    </div>
                    <div class="form-group">
                        <label>Total</label>
                        <input type="text" id="order-total" readonly>
                    </div>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="2"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary modal-cancel">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Order</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div id="toast-container"></div>

    <script src="app.js"></script>
</body>
</html>